{
  "name": "published_first_paper_expansion_v1",
  "description": "Published-first, arXiv-backed paper selection plan for the benchmark. Candidate citing papers are selected from published venues, then matched to arXiv twins with LaTeX source for automatic mining.",
  "selection_defaults": {
    "publication_year_start": 2020,
    "publication_year_end": 2026,
    "max_candidates_per_venue": 60,
    "target_papers_per_domain": 20,
    "target_instances_per_domain": 30,
    "max_instances_per_paper": 2
  },
  "build_targets": {
    "target_total_instances": 1000,
    "balanced_by_domain": true,
    "target_instances_per_domain": 200,
    "expected_instances_per_matched_paper": 1.6,
    "expected_match_rate": 0.75,
    "target_matched_papers_per_domain": 125,
    "target_candidates_per_domain": 180
  },
  "bootstrap_sources": {
    "openalex": {
      "fetch_multiplier": 3,
      "per_page": 50,
      "max_pages_per_venue": 6
    }
  },
  "triage_defaults": {
    "require_openalex_arxiv_link": true,
    "metadata_min_proof_rich_score": 4.5,
    "source_fetch_per_domain": 16,
    "shortlist_per_domain": 10,
    "max_shortlist_per_venue": 3,
    "min_bibliography_entries": 12,
    "min_proof_headings": 1,
    "min_theorem_like_envs": 4,
    "min_unique_cite_keys": 8,
    "min_proof_cite_keys": 2,
    "min_tool_citation_score": 2.0,
    "min_source_triage_score": 6.0
  },
  "candidate_routes": [
    {
      "name": "official_venue_pages",
      "purpose": "Primary route. Use journal and proceedings pages as the source of published-paper candidates."
    },
    {
      "name": "metadata_aggregator",
      "purpose": "Helper route. Normalize DOI, author, venue, and publication metadata."
    },
    {
      "name": "manual_seed",
      "purpose": "Fill undercovered domains or rare tool families with curator-provided published papers."
    }
  ],
  "matching_rules": {
    "accept_match_types": [
      "doi_exact",
      "title_author_year",
      "manual_verified"
    ],
    "automatic_reject_statuses": [
      "no_arxiv_twin",
      "ambiguous_match",
      "weak_title_alignment",
      "author_mismatch"
    ],
    "title_similarity_threshold": 0.94,
    "require_first_author_match": true,
    "year_tolerance": 2,
    "require_unique_best_candidate": true
  },
  "proof_rich_filter": {
    "positive_signals": [
      "main theorem proof present",
      "non-trivial bibliography",
      "multiple proof citations",
      "theorem/proposition/lemma structure",
      "theoretical article"
    ],
    "exclude_keywords": [
      "survey",
      "lecture notes",
      "thesis",
      "monograph",
      "book chapter",
      "erratum",
      "correction",
      "issue information",
      "toc",
      "table of contents",
      "editorial"
    ]
  },
  "domains": [
    {
      "domain": "analysis_pde",
      "seed_venues": [
        "Analysis & PDE",
        "Communications on Pure and Applied Mathematics",
        "Communications in Partial Differential Equations",
        "Duke Mathematical Journal",
        "Inventiones Mathematicae",
        "Journal of Functional Analysis",
        "Journal of the European Mathematical Society",
        "Annals of PDE"
      ],
      "fallback_arxiv_categories": [
        "math.AP",
        "math.CA"
      ]
    },
    {
      "domain": "geometry_topology",
      "seed_venues": [
        "Geometry & Topology",
        "Journal of Differential Geometry",
        "Duke Mathematical Journal",
        "Inventiones Mathematicae",
        "Journal of Topology"
      ],
      "fallback_arxiv_categories": [
        "math.DG",
        "math.GT"
      ]
    },
    {
      "domain": "algebra_number_theory",
      "seed_venues": [
        "Algebra & Number Theory",
        "International Mathematics Research Notices",
        "Journal of the American Mathematical Society",
        "Mathematical Research Letters",
        "Duke Mathematical Journal",
        "Inventiones Mathematicae",
        "Acta Mathematica"
      ],
      "fallback_arxiv_categories": [
        "math.AG",
        "math.NT"
      ]
    },
    {
      "domain": "combinatorics_discrete",
      "seed_venues": [
        "Combinatorica",
        "Electronic Journal of Combinatorics",
        "European Journal of Combinatorics",
        "Journal of Combinatorial Theory, Series A",
        "Journal of Combinatorial Theory, Series B",
        "Random Structures & Algorithms",
        "SIAM Journal on Discrete Mathematics"
      ],
      "fallback_arxiv_categories": [
        "math.CO"
      ]
    },
    {
      "domain": "probability_statistics_control",
      "seed_venues": [
        "Annals of Probability",
        "Annals of Applied Probability",
        "Probability Theory and Related Fields",
        "Annals of Statistics",
        "Journal of Machine Learning Research",
        "Journal of the ACM",
        "Mathematical Programming",
        "Mathematics of Operations Research",
        "Bernoulli",
        "SIAM Journal on Computing",
        "SIAM Journal on Control and Optimization",
        "SIAM Journal on Optimization"
      ],
      "fallback_arxiv_categories": [
        "math.PR",
        "stat.TH",
        "math.OC"
      ]
    }
  ],
  "tool_families": [
    "concentration_tail_bound",
    "compactness_embedding_existence",
    "spectral_perturbation_matrix_inequality",
    "convexity_duality_optimization",
    "counting_combinatorial_inequality",
    "algebraic_structure_lemma",
    "asymptotic_limit_theorem",
    "geometric_topological_criterion",
    "dynamics_ergodic_estimate",
    "other"
  ],
  "manifest_fields": [
    "paper_key",
    "domain",
    "published_title",
    "published_authors",
    "abstract",
    "notes",
    "venue",
    "year",
    "publication_date",
    "doi",
    "published_url",
    "published_source_route",
    "proof_rich_score",
    "proof_rich_signals",
    "openalex_work_id",
    "openalex_arxiv_id",
    "openalex_has_arxiv_link",
    "arxiv_id",
    "arxiv_title",
    "arxiv_url",
    "latex_link",
    "match_type",
    "match_confidence",
    "match_notes",
    "status"
  ]
}
